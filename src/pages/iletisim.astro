---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="İletişim — Ares Holding"
  description="Yatırım, ortaklık veya iş birliği için Ares Holding ekibiyle iletişime geçin. Merkez: Ataköy, İstanbul."
>
  <PageHero
    eyebrow="İletişim"
    title="Projenizi birlikte <em>değerlendirelim</em>"
    lede="Yatırım, ortaklık veya iş birliği için formu doldurun; ekibimiz en kısa sürede size dönüş yapsın."
  />

  <section class="section" aria-label="İletişim formu ve bilgileri">
    <div class="container contact__grid">
      <form class="form gs-reveal" id="iletisim-form" action="#" method="post">
        <div class="form__row">
          <div class="form__field">
            <label for="f-ad">Ad Soyad</label>
            <input id="f-ad" name="ad" type="text" placeholder="Adınız Soyadınız" autocomplete="name" required />
          </div>
          <div class="form__field">
            <label for="f-eposta">E-posta</label>
            <input id="f-eposta" name="eposta" type="email" placeholder="ornek@sirketiniz.com" autocomplete="email" required />
          </div>
        </div>
        <div class="form__field">
          <label for="f-mesaj">Mesajınız</label>
          <textarea id="f-mesaj" name="mesaj" rows="5" placeholder="Projenizden kısaca bahsedin…" required></textarea>
        </div>
        <div class="form__consent">
          <input type="checkbox" id="f-kvkk" name="kvkk" required aria-describedby="kvkk-link" />
          <label for="f-kvkk">
            KVKK Aydınlatma Metni’ni okudum; kişisel verilerimin bu kapsamda işlenmesini kabul
            ediyorum.
          </label>
        </div>
        <p class="form__kvkk-link" id="kvkk-link">
          <a href="/kvkk/" target="_blank" rel="noopener">Aydınlatma metnini yeni sekmede okuyun →</a>
        </p>
        <button class="btn btn--gold btn--block" type="submit" data-magnetic>Görüşme Talep Et</button>
        <noscript>
          <p class="form__note">
            Formu kullanabilmek için JavaScript gereklidir; dilerseniz talebinizi doğrudan
            <a class="link-gold" href="mailto:info@aresholding.com.tr">info@aresholding.com.tr</a>
            adresine iletebilirsiniz.
          </p>
        </noscript>
        <p class="form__note" role="status" aria-live="polite"></p>
      </form>

      <aside class="contact__aside gs-reveal" data-delay="1">
        <div class="contact__item">
          <h2>E-posta</h2>
          <a href="mailto:info@aresholding.com.tr">info@aresholding.com.tr</a>
        </div>
        <div class="contact__item">
          <h2>Merkez</h2>
          <p>
            Yalı Ataköy, Ataköy 2-5-6. Kısım,<br />
            Rauf Orbay Cd. C Blok No: 4 İç Kapı No: 65,<br />
            34158 Bakırköy / İstanbul
          </p>
        </div>
        <div class="contact__item">
          <h2>Çalışma Alanları</h2>
          <p>Yatırım &amp; Aracılık · Portföy Yönetimi · Teknoloji Yatırımları · Karton &amp; Ambalaj Üretimi</p>
        </div>
      </aside>
    </div>

    <!-- Harita: Ataköy -->
    <div class="container">
      <div class="contact__map gs-reveal">
        <iframe
          src="https://maps.google.com/maps?q=Yal%C4%B1%20Atak%C3%B6y%2C%20Atak%C3%B6y%202-5-6.%20K%C4%B1s%C4%B1m%2C%20Rauf%20Orbay%20Cd.%2C%2034158%20Bak%C4%B1rk%C3%B6y%2F%C4%B0stanbul&z=16&output=embed"
          title="Ares Holding merkez ofis konumu — Yalı Ataköy, Rauf Orbay Cd. C Blok No: 4, Bakırköy/İstanbul"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
        <!-- Ares logolu konum pini: embed sorgulanan konumu merkeze aldığından
             harita statik tutulur ve pin daima doğru noktayı gösterir -->
        <div class="map-pin" aria-hidden="true">
          <span class="map-pin__pulse"></span>
          <span class="map-pin__badge">
            <svg viewBox="0 0 64 64">
              <g transform="translate(13,21) scale(0.62)">
                <path d="M37.7 0 H47.1 L56.5 52 H43.3 L39.6 16.9 22.6 52 H0 Z" fill="#F2F0EB"></path>
                <polygon points="10.8,50.7 19.8,57.3 62.8,-0.7 53.8,-7.3" fill="#0A0A0A"></polygon>
                <polygon points="-1.6,75.7 -0.6,76.5 56.4,3.1 52.2,-0.1" fill="#F2F0EB"></polygon>
                <polygon points="67.8,-19.6 66.4,-8 56.5,-1.5 58,-13.2" fill="#F2F0EB"></polygon>
              </g>
            </svg>
          </span>
          <span class="map-pin__tail"></span>
        </div>
        <a
          class="btn btn--gold contact__map-ac"
          href="https://www.google.com/maps/search/?api=1&query=Yal%C4%B1%20Atak%C3%B6y%2C%20Atak%C3%B6y%202-5-6.%20K%C4%B1s%C4%B1m%2C%20Rauf%20Orbay%20Cd.%2C%2034158%20Bak%C4%B1rk%C3%B6y%2F%C4%B0stanbul"
          target="_blank"
          rel="noopener">Haritada Aç<span class="btn__arrow" aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
