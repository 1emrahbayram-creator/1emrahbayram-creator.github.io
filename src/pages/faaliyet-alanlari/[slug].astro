---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABand from '../../components/CTABand.astro';
import { sektorler } from '../../data/sektorler';

export function getStaticPaths() {
  return sektorler.map((s) => ({ params: { slug: s.slug }, props: { sektor: s } }));
}

const { sektor } = Astro.props;
const digerleri = sektorler.filter((s) => s.slug !== sektor.slug);

// Anasayfa kartlarındaki canvas görsellerinin detay sayfası eşlemesi
const gorselMap: Record<string, string> = {
  yatirim: 'kure',
};
---

<BaseLayout
  title={`${sektor.title} — Ares Holding`}
  description={sektor.metaAciklama}
>
  <PageHero
    eyebrow={sektor.kisaAd}
    title={sektor.manset}
    lede={sektor.ozet}
    no={sektor.no}
    crumbs={[
      { href: '/', label: 'Ana Sayfa' },
      { href: '/faaliyet-alanlari/', label: 'Faaliyet Alanları' },
    ]}
  >
    {gorselMap[sektor.slug] && (
      <canvas
        slot="arka"
        class="stack__globe"
        data-gorsel={gorselMap[sektor.slug]}
        aria-hidden="true"></canvas>
    )}
  </PageHero>

  <!-- AÇIKLAMA -->
  <section class="section" aria-labelledby="detay-baslik">
    <div class="container">
      <div class="leadership__grid" style="align-items: start;">
        <div class="gs-reveal">
          <h2 class="section__title" id="detay-baslik">Bu alanda <em>neler yapıyoruz?</em></h2>
        </div>
        <div class="gs-reveal" data-delay="1">
          {sektor.aciklama.map((p) => (
            <p style="color: var(--muted); margin-bottom: 1.25rem;">{p}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HİZMETLER -->
  <section class="section section--elev grid-bg" aria-labelledby="hizmet-baslik">
    <div class="container">
      <div class="section__head gs-reveal">
        <h2 class="section__title" id="hizmet-baslik">Uzmanlık <em>alanlarımız</em></h2>
      </div>
      <ul class="service-list">
        {sektor.hizmetler.map((h, i) => (
          <li class="gs-reveal" data-delay={String(i % 2)}>
            <strong>{h.ad}</strong>
            <span>{h.detay}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- DİĞER ALANLAR -->
  <section class="section" aria-labelledby="diger-baslik">
    <div class="container">
      <div class="section__head gs-reveal">
        <h2 class="section__title" id="diger-baslik">Diğer <em>iş kollarımız</em></h2>
      </div>
      <div class="sector-grid sector-grid--three">
        {digerleri.map((s) => (
          <article class="card sector-card gs-reveal" data-tilt style="min-height: 200px;">
            <div class="card__glare" aria-hidden="true"></div>
            <div class="sector-card__top">
              <span class="sector-card__no">{s.no}</span>
              <svg class="sector-card__icon" viewBox="0 0 48 48" aria-hidden="true" set:html={s.ikon} style="width: 36px; height: 36px;" />
            </div>
            <h3 class="sector-card__title" style="font-size: 1.25rem;">
              <a class="sector-card__stretch" href={`/faaliyet-alanlari/${s.slug}/`}>{s.title}</a>
            </h3>
            <span class="sector-card__link" aria-hidden="true">İncele<span class="btn__arrow">→</span></span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    baslik={`${sektor.kisaAd} alanında <em>birlikte çalışalım.</em>`}
    altMetin="Projenizi değerlendirmek için ekibimizle bir görüşme planlayın."
  />
</BaseLayout>

<style>
  .sector-grid--three { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 860px) {
    .sector-grid--three { grid-template-columns: 1fr; }
  }
</style>
