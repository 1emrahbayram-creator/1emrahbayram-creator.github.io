---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sayfa Bulunamadı — Ares Holding"
  description="Aradığınız sayfa bulunamadı."
  noindex
>
  <section class="not-found grid-bg">
    <div>
      <p class="not-found__code" aria-hidden="true">404</p>
      <h1 class="section__title" style="margin: 1.5rem auto;">Aradığınız sayfa <em>bulunamadı</em></h1>
      <p style="color: var(--muted); margin-bottom: 2rem;">
        Sayfa taşınmış veya adres hatalı yazılmış olabilir.
      </p>
      <a class="btn btn--gold" href="/" data-magnetic>Ana Sayfaya Dön</a>
    </div>
  </section>
</BaseLayout>
