---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ticker from '../components/Ticker.astro';
import CTABand from '../components/CTABand.astro';
import { sektorler } from '../data/sektorler';

const uzmanlikSayisi = sektorler.reduce((t, s) => t + s.hizmetler.length, 0);
---

<BaseLayout
  title="Ares Holding — Küresel Vizyonla Değer Üreten Yatırım Gücü"
  description="Ares Holding A.Ş. — İstanbul merkezli yatırım grubu. Finans, gayrimenkul, akıllı kent teknolojileri ve uluslararası ticarette değer üretiyoruz."
>
  <!-- HERO -->
  <section class="hero" aria-labelledby="hero-baslik">
    <div class="hero__glow" aria-hidden="true"></div>
    <svg class="hero__arcs" viewBox="0 0 1200 800" aria-hidden="true" preserveAspectRatio="xMidYMax slice">
      <circle cx="600" cy="820" r="240"></circle>
      <circle cx="600" cy="820" r="380"></circle>
      <circle cx="600" cy="820" r="520"></circle>
      <circle cx="600" cy="820" r="660"></circle>
      <circle cx="600" cy="820" r="800"></circle>
    </svg>
    <div class="container hero__inner">
      <h1 class="hero__title gs-hero" id="hero-baslik">
        Sermayeyi vizyonla,<br />vizyonu <em>kalıcı değerle</em><br />buluşturuyoruz.
      </h1>
      <p class="hero__sub gs-hero">
        Ares Holding; finans ve sermaye piyasalarından gayrimenkul geliştirmeye, akıllı kent
        teknolojilerinden uluslararası ticarete uzanan iş kollarıyla, büyümeye hazır projelerin
        stratejik yatırım ortağıdır.
      </p>
      <div class="hero__actions gs-hero">
        <a class="btn btn--gold" href="/faaliyet-alanlari/" data-magnetic>Faaliyet Alanlarımız</a>
        <a class="btn btn--ghost" href="/iletisim/" data-magnetic>
          Projenizi Görüşelim<span class="btn__arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <p class="hero__trust gs-hero">
        Finans <span aria-hidden="true">•</span> Gayrimenkul <span aria-hidden="true">•</span>
        Teknoloji <span aria-hidden="true">•</span> Uluslararası Ticaret
      </p>
    </div>
    <p class="hero__scroll-hint" aria-hidden="true">Keşfet</p>
  </section>

  <Ticker />

  <!-- HAKKIMIZDA ÖZETİ + İSTATİSTİK -->
  <section class="section" aria-labelledby="ozet-baslik">
    <div class="container">
      <div class="leadership__grid">
        <div class="gs-reveal">
          <h2 class="section__title" id="ozet-baslik">
            Tek çatı altında bütünleşik bir <em>değer zinciri</em>
          </h2>
          <p class="leadership__text">
            Küresel piyasalarda finansal kaynak yaratma, uluslararası ticaret ve teknolojik altyapı
            yatırımları üzerine odaklanmış çok yönlü bir şirketler grubuyuz. Arsa temininden proje
            yönetimine, offshore fon süreçlerinden şirket birleşmelerine kadar tüm süreçleri kendi
            uzman kadromuzla yürütürüz.
          </p>
          <p class="leadership__text" style="margin-top: 1rem;">
            <a class="link-gold" href="/hakkimizda/">Kurumsal profilimizi inceleyin →</a>
          </p>
        </div>
        <dl class="stats gs-reveal" data-delay="1" style="border-top: none; grid-template-columns: repeat(2, 1fr); gap: 0.5rem 2rem;">
          <div class="stats__item">
            <dt>Ana İş Kolu</dt>
            <dd><span class="stats__num" data-count="4">4</span></dd>
          </div>
          <div class="stats__item">
            <dt>Uzmanlık Alanı</dt>
            <dd><span class="stats__num" data-count={String(uzmanlikSayisi)}>{uzmanlikSayisi}</span></dd>
          </div>
          <div class="stats__item">
            <dt>Uzman Kadro</dt>
            <dd>51–200</dd>
          </div>
          <div class="stats__item">
            <dt>Küresel Merkez</dt>
            <dd class="stats__word">İstanbul</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- SEKTÖR KARTLARI -->
  <section class="section section--elev grid-bg" aria-labelledby="sektor-baslik">
    <div class="container">
      <div class="section__head gs-reveal">
        <h2 class="section__title" id="sektor-baslik">Birbirini besleyen <em>dört ana iş kolu</em></h2>
        <p class="section__lede">
          Her iş kolumuz kendi alanında derinleşirken, grup sinerjisiyle ortak değer üretir.
        </p>
      </div>
      <div class="sector-grid">
        {sektorler.map((s, i) => (
          <article class="card sector-card gs-reveal" data-tilt data-delay={String(i % 2)}>
            <div class="card__glare" aria-hidden="true"></div>
            <div class="sector-card__top">
              <span class="sector-card__no">{s.no}</span>
              <svg class="sector-card__icon" viewBox="0 0 48 48" aria-hidden="true" set:html={s.ikon} />
            </div>
            <h3 class="sector-card__title">
              <a class="sector-card__stretch" href={`/faaliyet-alanlari/${s.slug}/`}>{s.title}</a>
            </h3>
            <p class="sector-card__desc">{s.ozet}</p>
            <span class="sector-card__link" aria-hidden="true">
              İncele<span class="btn__arrow">→</span>
            </span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- YAKLAŞIM -->
  <section class="section" aria-labelledby="yaklasim-baslik">
    <div class="container">
      <div class="section__head gs-reveal">
        <h2 class="section__title" id="yaklasim-baslik">Dört adımda <em>sürdürülebilir değer</em></h2>
        <p class="section__lede">
          Her yatırımda aynı disiplini uygularız: önce anlamak, sonra kalıcı sistem kurmak.
        </p>
      </div>
      <ol class="process__grid">
        <li class="process__step gs-reveal">
          <span class="process__no" aria-hidden="true">01</span>
          <h3>Analiz</h3>
          <p>Pazar, proje ve finansal yapının derinlemesine durum tespiti; risk haritasının çıkarılması.</p>
        </li>
        <li class="process__step gs-reveal" data-delay="1">
          <span class="process__no" aria-hidden="true">02</span>
          <h3>Yapılandırma</h3>
          <p>Ortaklık modeli, finansman kurgusu ve hukuki zeminin projeye özel tasarlanması.</p>
        </li>
        <li class="process__step gs-reveal" data-delay="2">
          <span class="process__no" aria-hidden="true">03</span>
          <h3>Uygulama</h3>
          <p>Uzman kadrolarımızla operasyonun hayata geçirilmesi ve aktif süreç yönetimi.</p>
        </li>
        <li class="process__step gs-reveal" data-delay="3">
          <span class="process__no" aria-hidden="true">04</span>
          <h3>Büyüme</h3>
          <p>Performans takibi, ölçeklendirme ve değerin sürdürülebilir kılınması.</p>
        </li>
      </ol>
    </div>
  </section>

  <CTABand />
</BaseLayout>
